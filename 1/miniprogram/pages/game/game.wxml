<view class="game-container">
  <view class="game-header">
    <view class="header-left">
      <text class="flag-icon">🚩</text>
      <text class="flag-text">{{flagCount}}</text>
    </view>
    <view class="header-center" bindtap="restartGame">
      <text class="status-icon">{{gameStatusIcon}}</text>
    </view>
    <view class="header-right">
      <text class="timer-icon">⏱️</text>
      <text class="timer-text">{{formatTime(gameTime)}}</text>
    </view>
  </view>

  <view class="board-area">
    <view class="board">
      <view 
        wx:for="{{board}}" 
        wx:key="index"
        class="cell {{board[index].revealed ? 'revealed' : ''}} {{board[index].flagged ? 'flagged' : ''}}"
        data-index="{{index}}"
        bindtap="handleTap"
        bindlongpress="handleLongPress"
      >
        <text>{{board[index].displayText}}</text>
      </view>
    </view>
  </view>

  <view class="actions">
    <view bindtap="goHome">返回</view>
    <view bindtap="restartGame">重新开始</view>
  </view>

  <view wx:if="{{showModal}}" class="modal">
    <view class="modal-content">
      <view class="modal-icon">{{isWin ? '🎉' : '💥'}}</view>
      <view class="modal-title">{{isWin ? '恭喜获胜！' : '游戏结束'}}</view>
      <view class="modal-time">用时：{{formatTime(gameTime)}}</view>
      <view wx:if="{{isNewRecord}}" class="new-record">🏆 新纪录！</view>
      <view class="modal-buttons">
        <view class="modal-btn" bindtap="goHome">返回首页</view>
        <view class="modal-btn primary" bindtap="restartGame">再来一局</view>
      </view>
    </view>
  </view>
</view>