.game-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2d3436 0%, #1a1a2e 100%);
  display: flex;
  flex-direction: column;
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(0, 0, 0, 0.3);
}

.header-left, .header-right {
  width: 80rpx;
}

.header-center {
  flex: 1;
  display: flex;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #fff;
}

.show-mines {
  font-size: 36rpx;
}

.flag-counter, .timer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #1a1a2e;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
}

.flag-icon, .timer-icon {
  font-size: 28rpx;
}

.flag-count, .timer-count {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  font-family: monospace;
}

.face {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(231, 76, 60, 0.4);
}

.face-icon {
  font-size: 48rpx;
}

.board-container {
  flex: 1;
  padding: 20rpx;
  overflow: auto;
}

.board {
  display: grid;
  grid-template-columns: repeat(9, 44rpx);
  grid-gap: 4rpx;
  background: #34495e;
  border-radius: 16rpx;
  padding: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.cell-hidden {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #7f8c8d 0%, #95a5a6 50%, #7f8c8d 100%);
  border: 2rpx solid #6c7a7a;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 2rpx;
  border-radius: 6rpx;
  transition: all 0.15s;
}

.cell-hidden:active {
  transform: scale(0.95);
  background: #95a5a6;
}

.cell-revealed {
  width: 44rpx;
  height: 44rpx;
  background: #ecf0f1;
  border: 2rpx solid #bdc3c7;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 2rpx;
  border-radius: 6rpx;
}

.cell-flagged {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  border: 2rpx solid #d68910;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 2rpx;
  border-radius: 6rpx;
}

.cell-mine {
  width: 44rpx;
  height: 44rpx;
  background: #e74c3c;
  border: 2rpx solid #c0392b;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 2rpx;
  border-radius: 6rpx;
}

.cell-error {
  width: 44rpx;
  height: 44rpx;
  background: #ff0000;
  border: 2rpx solid #cc0000;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 2rpx;
  border-radius: 6rpx;
  color: white;
  font-size: 20rpx;
}

.cell-number-1,
.cell-number-2,
.cell-number-3,
.cell-number-4,
.cell-number-5,
.cell-number-6,
.cell-number-7,
.cell-number-8 {
  width: 44rpx;
  height: 44rpx;
  background: #ecf0f1;
  border: 2rpx solid #bdc3c7;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 2rpx;
  border-radius: 6rpx;
}

.cell-text {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
}

.cell-number-1 .cell-text { color: #3498db; }
.cell-number-2 .cell-text { color: #27ae60; }
.cell-number-3 .cell-text { color: #e74c3c; }
.cell-number-4 .cell-text { color: #8e44ad; }
.cell-number-5 .cell-text { color: #f39c12; }
.cell-number-6 .cell-text { color: #1abc9c; }
.cell-number-7 .cell-text { color: #c0392b; }
.cell-number-8 .cell-text { color: #2c3e50; }

.game-over-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: linear-gradient(180deg, #34495e 0%, #2c3e50 100%);
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  text-align: center;
  min-width: 500rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.5);
}

.modal-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.modal-time {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 40rpx;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #fff;
}

.modal-btn.secondary {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}