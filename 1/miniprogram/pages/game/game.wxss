.game-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #2d3436 0%, #1e272e 100%);
  display: flex;
  flex-direction: column;
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(0, 0, 0, 0.3);
}

.header-left, .header-right {
  width: 140rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #000;
  border-radius: 10rpx;
  padding: 10rpx 20rpx;
}

.header-center {
  width: 80rpx;
  height: 80rpx;
  background: #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.flag-icon, .timer-icon {
  font-size: 24rpx;
}

.flag-text, .timer-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6b6b;
  font-family: monospace;
}

.status-icon {
  font-size: 40rpx;
}

.board-area {
  flex: 1;
  padding: 20rpx;
  display: flex;
  justify-content: center;
  align-items: flex-start;
}

.board {
  display: grid;
  grid-template-columns: repeat(9, 1fr);
  background: #555;
  padding: 2rpx;
  border-radius: 8rpx;
  width: 100%;
  max-width: 500rpx;
}

.cell {
  aspect-ratio: 1;
  background: #8b8b8b;
  border: 2rpx solid #666;
  border-bottom: 3rpx solid #444;
  border-right: 3rpx solid #444;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  box-sizing: border-box;
}

.cell:active {
  background: #999;
}

.cell.revealed {
  background: #dfe6e9;
  border: 1rpx solid #ccc;
}

.cell.flagged {
  background: #fdcb6e;
}

.actions {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 30rpx;
  background: rgba(0, 0, 0, 0.3);
}

.actions view {
  padding: 20rpx 40rpx;
  background: #6c5ce7;
  color: #fff;
  border-radius: 20rpx;
  font-size: 28rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  background: linear-gradient(135deg, #2d3436 0%, #1e272e 100%);
  border-radius: 40rpx;
  padding: 60rpx;
  text-align: center;
  width: 85%;
  max-width: 550rpx;
}

.modal-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.modal-time {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
}

.new-record {
  font-size: 36rpx;
  color: #ffd700;
  margin-bottom: 30rpx;
}

.modal-buttons {
  display: flex;
  justify-content: center;
  gap: 30rpx;
}

.modal-btn {
  padding: 25rpx 50rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%);
}