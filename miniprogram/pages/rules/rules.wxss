.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2d3436 0%, #1a1a2e 100%);
  padding-bottom: 60rpx;
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(0, 0, 0, 0.3);
}
.back-btn {
  font-size: 48rpx;
  color: #fff;
  width: 80rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}
.placeholder {
  width: 80rpx;
}
.content {
  padding: 32rpx;
}
.section {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
  display: block;
}
.rule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}
.rule-icon {
  font-size: 32rpx;
  width: 48rpx;
}
.rule-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #667eea;
  width: 40rpx;
  text-align: center;
}
.rule-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}
.difficulty-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.difficulty-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}
.difficulty-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}
.difficulty-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}
.tip-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.tip-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  padding-left: 24rpx;
  border-left: 4rpx solid #11998e;
}