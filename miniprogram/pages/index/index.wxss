.container {
  padding: 40rpx 32rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #2d3436 0%, #1a1a2e 100%);
}
.header {
  text-align: center;
  padding: 60rpx 0 80rpx;
}
.logo {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
.title {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}
.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
}
.stats {
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}
.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}
.mode-section {
  margin-bottom: 40rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
  display: block;
}
.mode-buttons {
  display: flex;
  gap: 20rpx;
}
.mode-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  transition: all 0.3s;
}
.mode-btn.single.active, .mode-btn.single:active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
}
.mode-btn.online.active, .mode-btn.online:active {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  border-color: transparent;
}
.mode-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}
.mode-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}
.mode-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}
.difficulty-section {
  margin-bottom: 40rpx;
}
.difficulty-buttons {
  display: flex;
  gap: 20rpx;
}
.diff-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  transition: all 0.3s;
}
.diff-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
}
.diff-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}
.diff-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}
.tips {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}
.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
  display: block;
}
.tip-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.tip-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}
.start-btn {
  width: 100%;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  border: none;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 12rpx 32rpx rgba(17, 153, 142, 0.4);
}
.start-btn:active {
  transform: scale(0.98);
}
.start-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}
.start-icon {
  font-size: 40rpx;
}
.footer-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}
.footer-btn {
  flex: 1;
  min-width: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
}
.footer-btn:active {
  background: rgba(255, 255, 255, 0.15);
}
.footer-icon {
  font-size: 28rpx;
}
.footer-text {
  font-size: 24rpx;
  color: #fff;
}
.test-section {
  margin-top: 20rpx;
  padding: 0 40rpx;
}
.test-btn {
  width: 100%;
  background: rgba(243, 156, 18, 0.2);
  border: 2rpx solid rgba(243, 156, 18, 0.5);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #f39c12;
}
.test-btn:active {
  background: rgba(243, 156, 18, 0.3);
}