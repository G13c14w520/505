.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2d3436 0%, #1a1a2e 100%);
  padding-bottom: 60rpx;
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(0, 0, 0, 0.3);
}
.back-btn {
  font-size: 48rpx;
  color: #fff;
  width: 80rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}
.placeholder {
  width: 80rpx;
}
.mode-select {
  display: flex;
  margin: 40rpx 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  overflow: hidden;
}
.mode-tab {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.3s;
}
.mode-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: 600;
}
.content {
  padding: 0 32rpx;
}
.form-group {
  margin-bottom: 40rpx;
}
.form-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
  display: block;
}
.form-input {
  width: 100%;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 36rpx;
  color: #fff;
  box-sizing: border-box;
  line-height: 96rpx;
}
.form-input.room-input {
  font-family: monospace;
  letter-spacing: 16rpx;
}
.form-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 32rpx;
}
.difficulty-options {
  display: flex;
  gap: 20rpx;
}
.diff-option {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  transition: all 0.3s;
}
.diff-option.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  color: #fff;
}
.create-btn, .join-btn {
  width: 100%;
  padding: 32rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  border: none;
  margin-top: 20rpx;
}
.create-btn {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}
.join-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
.create-btn[disabled], .join-btn[disabled] {
  opacity: 0.5;
}
.waiting-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}
.waiting-content {
  background: linear-gradient(180deg, #34495e 0%, #2c3e50 100%);
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  text-align: center;
  min-width: 500rpx;
}
.waiting-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}
.waiting-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}
.waiting-room {
  font-size: 32rpx;
  color: #f39c12;
  font-family: monospace;
  display: block;
  margin-bottom: 16rpx;
}
.waiting-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 40rpx;
}
.cancel-btn {
  padding: 24rpx 48rpx;
  background: rgba(255, 255, 255, 0.2);
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
}