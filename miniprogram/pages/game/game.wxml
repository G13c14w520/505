<view class="game-container">
  <view class="game-header">
    <view class="header-left">
      <view class="back-icon" bindtap="goHome">←</view>
    </view>
    <view class="header-center">
      <view class="face" bindtap="restart">
        <text class="face-icon">{{ face }}</text>
      </view>
    </view>
    <view class="header-right">
      <view class="flag-counter">
        <text class="flag-icon">🚩</text>
        <text class="flag-count">{{ mineCount - flagCount }}</text>
      </view>
    </view>
  </view>
  <view class="timer">
    <text class="timer-icon">⏱</text>
    <text class="timer-count">{{ displayTime }}</text>
  </view>
  <view wx:if="{{ mode === 'online' }}" class="online-info">
    <view class="player-info">
      <text class="player-name">{{ playerName }} ({{ isMyTurn ? '你的回合' : '对手回合' }})</text>
    </view>
    <view class="score-info">
      <text class="score-text">比分: {{ player1Score }} - {{ player2Score }}</text>
    </view>
  </view>
  <view class="board-container">
    <view class="board" style="grid-template-columns: repeat({{ cols }}, {{ cellSize }}rpx);">
      <view 
        wx:for="{{ cells }}" 
        wx:key="id"
        class="{{ item.class }} {{ !isMyTurn && mode === 'online' ? 'cell-disabled' : '' }}"
        style="width: {{ cellSize }}rpx; height: {{ cellSize }}rpx;"
        data-id="{{ item.id }}"
        bindtap="handleTap"
        bindlongpress="handleLongPress"
      >
        <text class="cell-text">{{ item.text }}</text>
      </view>
    </view>
  </view>
  <view wx:if="{{ showModal }}" class="game-over-modal">
    <view class="modal-content">
      <text class="modal-icon">{{ isWin ? '🎉' : '💥' }}</text>
      <text class="modal-title">{{ isWin ? '恭喜获胜！' : '游戏结束' }}</text>
      <text class="modal-time">用时：{{ displayTime }}</text>
      <view wx:if="{{ mode === 'online' }}" class="modal-score">
        <text class="score-label">最终比分</text>
        <text class="score-value">{{ player1Score }} - {{ player2Score }}</text>
      </view>
      <view class="modal-buttons">
        <button class="modal-btn primary" bindtap="restart">再来一局</button>
        <button class="modal-btn secondary" bindtap="goHome">返回首页</button>
      </view>
    </view>
  </view>
</view>