<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">←</view>
    <text class="title">🏆 排行榜</text>
    <view class="placeholder"></view>
  </view>
  <view class="filter-tabs">
    <view 
      class="filter-tab {{ currentFilter === 'all' ? 'active' : '' }}"
      bindtap="selectFilter"
      data-filter="all"
    >全部</view>
    <view 
      class="filter-tab {{ currentFilter === 'easy' ? 'active' : '' }}"
      bindtap="selectFilter"
      data-filter="easy"
    >简单</view>
    <view 
      class="filter-tab {{ currentFilter === 'medium' ? 'active' : '' }}"
      bindtap="selectFilter"
      data-filter="medium"
    >中等</view>
    <view 
      class="filter-tab {{ currentFilter === 'hard' ? 'active' : '' }}"
      bindtap="selectFilter"
      data-filter="hard"
    >困难</view>
  </view>
  <view class="test-area">
    <button class="test-btn" bindtap="testConnection">🔗 测试连接</button>
    <button class="test-btn" bindtap="testSaveScore">📝 测试保存分数</button>
  </view>
  <view class="leaderboard-list">
    <view wx:if="{{ leaderboard.length === 0 }}" class="empty-state">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无记录</text>
    </view>
    <view 
      wx:for="{{ leaderboard }}" 
      wx:key="_id" 
      class="leaderboard-item"
    >
      <view class="rank">
        <text class="rank-number {{ index < 3 ? 'top-three' : '' }}">{{ index + 1 }}</text>
      </view>
      <view class="info">
        <text class="player-name">{{ item.playerName || '匿名玩家' }}</text>
        <text class="difficulty-tag">{{ getDifficultyText(item.difficulty) }}</text>
      </view>
      <view class="time">
        <text class="time-value">{{ item.formattedTime || '--:--' }}</text>
        <text class="time-label">用时</text>
      </view>
    </view>
  </view>
</view>