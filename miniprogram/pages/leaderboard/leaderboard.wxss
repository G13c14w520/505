.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2d3436 0%, #1a1a2e 100%);
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(0, 0, 0, 0.3);
}
.back-btn {
  font-size: 48rpx;
  color: #fff;
  width: 80rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}
.placeholder {
  width: 80rpx;
}
.filter-tabs {
  display: flex;
  padding: 20rpx 32rpx;
  gap: 16rpx;
}
.filter-tab {
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.3s;
}
.filter-tab.active {
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  color: #fff;
}
.test-area {
  display: flex;
  padding: 0 32rpx 20rpx;
  gap: 16rpx;
}
.test-btn {
  flex: 1;
  padding: 16rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  border: none;
}
.leaderboard-list {
  padding: 0 32rpx;
}
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}
.leaderboard-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.rank {
  width: 60rpx;
  text-align: center;
}
.rank-number {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.5);
}
.rank-number.top-three {
  color: #f39c12;
}
.rank-number:nth-child(2) {
  color: #95a5a6;
}
.info {
  flex: 1;
  padding: 0 20rpx;
}
.player-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}
.difficulty-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}
.time {
  text-align: right;
}
.time-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #11998e;
  display: block;
  font-family: monospace;
}
.time-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}