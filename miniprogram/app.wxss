page {
  background-color: #2d3436;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}
.container {
  padding: 20rpx;
  box-sizing: border-box;
}
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin: 20rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}
.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}
.card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 20rpx 0;
  backdrop-filter: blur(10px);
}
.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  margin-bottom: 20rpx;
}
.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
}